---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="min-h-screen bg-black text-white">
    
    <!-- Hero Section -->
    <section class="flex flex-col items-center justify-center h-screen text-center px-4">
      <h1 class="text-6xl font-bold tracking-tight mb-4">Deanography</h1>
      <p class="text-xl text-gray-400 mb-8">Fine art photography — available to own</p>
      <a href="/gallery" class="bg-white text-black px-8 py-3 text-sm font-semibold tracking-widest uppercase hover:bg-gray-200 transition">
        Browse Gallery
      </a>
    </section>

  </main>
</Layout>