---
import Layout from '../layouts/Layout.astro';
import { sanityClient } from '../lib/sanity';

const photos = await sanityClient.fetch(`
  *[_type == "photo"] | order(_createdAt desc) {
    title,
    slug,
    location,
    price,
    category,
    "imageUrl": previewImage.asset->url,
    "imageWidth": previewImage.asset->metadata.dimensions.width,
    "imageHeight": previewImage.asset->metadata.dimensions.height
  }
`);
---

<Layout>
  <main class="min-h-screen bg-white text-gray-900">

    <div class="header">
      <p class="subtitle">Fine art photography — available to own</p>
    </div>

    <div class="grid">
      {photos.map((photo: any) => (
        <a
          href={`/photo/${photo.slug.current}`}
          class={`card ${photo.imageHeight > photo.imageWidth ? 'card-portrait' : ''}`}
        >
          <img src={photo.imageUrl} alt={photo.title} class="card-img" />
          <div class="card-overlay">
            <p class="card-title">{photo.title}</p>
            <p class="card-location">{photo.location}</p>
            <p class="card-price">from {photo.price}€</p>
          </div>
        </a>
      ))}
    </div>

  </main>
</Layout>

<style>
  .header {
    max-width: 1400px;
    margin: 0 auto;
    padding: 4rem 3rem 2rem;
  }
  .subtitle {
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #555;
    font-weight: 400;
    margin: 0;
  }
  .grid {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 3rem 6rem;
    row-gap: 3rem;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }
  .card {
    display: block;
    position: relative;
    overflow: hidden;
    background: #111;
    aspect-ratio: 3/2;
    text-decoration: none;
  }
  .card-portrait {
    aspect-ratio: 3/4;
  }
  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }
  .card:hover .card-img {
    transform: scale(1.04);
  }
  .card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 50%);
    opacity: 0;
    transition: opacity 0.4s ease;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 2rem;
  }
  .card:hover .card-overlay {
    opacity: 1;
  }
  .card-title {
    color: #fff;
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0 0 4px;
  }
  .card-location {
    color: #aaa;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin: 0 0 8px;
  }
  .card-price {
    color: #fff;
    font-size: 0.9rem;
    font-weight: 700;
    margin: 0;
  }
</style>