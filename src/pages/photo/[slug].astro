---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { sanityClient } from '../../lib/sanity';
import PhotoDetail from '../../components/PhotoDetail';

const { slug } = Astro.params;

const photo = await sanityClient.fetch(`
  *[_type == "photo" && slug.current == $slug][0] {
    title,
    "slug": slug.current,
    location,
    description,
    price,
    category,
    "imageUrl": previewImage.asset->url,
    "imageWidth": previewImage.asset->metadata.dimensions.width,
    "imageHeight": previewImage.asset->metadata.dimensions.height
  }
`, { slug });

if (!photo) {
  return Astro.redirect('/');
}
---

<Layout>
  <main class="min-h-screen bg-white text-gray-900">
    <PhotoDetail client:load photo={photo} />
  </main>
</Layout>