---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { sanityClient } from '../../lib/sanity';
import PrintSelector from '../../components/PrintSelector';

const { slug } = Astro.params;

const photo = await sanityClient.fetch(
  `
  *[_type == "photo" && slug.current == $slug][0] {
    title,
    "slug": slug.current,
    location,
    description,
    price,
    category,
    "imageUrl": previewImage.asset->url
  }
`,
  { slug },
);

if (!photo) {
  return Astro.redirect('/gallery');
}
---

<Layout>
  <main class="min-h-screen bg-black text-white">

    <div class="px-6 pt-10">
      <a href="/" class="text-gray-500 text-sm tracking-widest uppercase hover:text-white transition">Gallery</a>
    </div>

    <div class="max-w-6xl mx-auto px-6 py-10 grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">

      <img src={photo.imageUrl} alt={photo.title} class="w-full rounded-sm" />

      <div class="flex flex-col gap-6">
        <div>
          <h1 class="text-4xl font-bold">{photo.title}</h1>
          <p class="text-gray-400 mt-2 text-sm tracking-widest uppercase">{photo.location}</p>
        </div>

        <p class="text-gray-300 leading-relaxed">{photo.description}</p>

        <PrintSelector
          client:load
          imageUrl={photo.imageUrl}
          title={photo.title}
          slug={photo.slug}
          digitalPrice={photo.price}
        />
      </div>

    </div>
  </main>
</Layout>